# nexsys-bench — stable Zigbee coordinator handle + autosuspend off
# Fill <VID>/<PID>/<SERIAL> from Step 3 of the Phase-0 runbook:
#   ssh pi 'udevadm info -q property -n /dev/serial/by-id/<PORT> | grep -E "ID_VENDOR_ID|ID_MODEL_ID|ID_SERIAL_SHORT"'
# Install: sudo cp 99-zigbee-coordinator.rules /etc/udev/rules.d/ && sudo udevadm control --reload && sudo udevadm trigger
#
# Why: /dev/ttyACM* renumbers across reboots/replugs (unstable); a coordinator that gets USB-autosuspended drops the
# serial link mid-capture (a real failure mode — assessment showed autosuspend=2). This pins a stable /dev/zigbee
# symlink and forces power/control=on (no autosuspend) for THIS device only.

# Filled 2026-07-01 from Phase-0 Step-3 measured fingerprint (SONOFF Dongle-PMG24, hs-dev-1):
SUBSYSTEM=="tty", ATTRS{idVendor}=="10c4", ATTRS{idProduct}=="ea60", ATTRS{serial}=="0ae2dd7cecf8ef11b80168135c2a50c9", SYMLINK+="zigbee", MODE="0660", GROUP="dialout"
ACTION=="add", SUBSYSTEM=="usb", ATTRS{idVendor}=="10c4", ATTRS{idProduct}=="ea60", ATTRS{serial}=="0ae2dd7cecf8ef11b80168135c2a50c9", TEST=="power/control", ATTR{power/control}="on"
